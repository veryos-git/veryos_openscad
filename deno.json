{
  "name": "@apn/websersocketgui",
  "version": "0.4.2",
  "license": "GPL-2.0-only",
  "exports": {
    ".": "./exports.js",
    "./init": "./serverside/init.js"
  },
  "publish": {
    "exclude": [
      "AI_responses_summaries.md",
      "planning/"
    ]
  },
  "tasks": {
    "run": "B_DENO_TASK=1 deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi --allow-run --env websersocket_bc59b998-2abf-40eb-bf5c-5048f1c8636e.js",
    "stop": "pkill -f 'deno run.*websersocket_bc59b998-2abf-40eb-bf5c-5048f1c8636e.js' || echo 'No running websersocket process found.'",
    "restart": "deno task stop && deno task run",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env --allow-ffi serverside/function_testings.js",
    "uninit": "deno run --allow-read --allow-write --allow-env --env serverside/uninit.js",
    "rmdb": "rm -rf ./.gitignored/appdb/ && echo 'Database cleared.'"
  },
  "imports": {
    "@apn/websersocketgui/constructors_framework": "./localhost/constructors_framework.js",
    "@std/fs": "jsr:@std/fs@^1.0.23"
  }
}
